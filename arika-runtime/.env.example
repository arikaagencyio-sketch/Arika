# Arika Runtime environment. Copy to `.env` and fill in. `.env` is gitignored.

# Required for the local runtime to call Claude (manual/CLI/event/webhook runs).
# Production scheduled runs use Anthropic cloud routines + connector auth instead,
# and do not need this key.
ANTHROPIC_API_KEY=

# Port the Fastify webhook server listens on (POST /webhook/:source).
WEBHOOK_PORT=8080

# Absolute or repo-relative path to finos-plugin's built output. Leave blank to
# use the default: <repo-root>/09_Finance/finos-plugin/dist
FINOS_DIST=
