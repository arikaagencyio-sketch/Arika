{
  "name": "arika-runtime",
  "version": "0.1.0",
  "description": "Unified agent runtime for Arika Agency's OS — one canonical spec format + one executor that runs every department's agents from manual, cron, event, and webhook triggers.",
  "type": "module",
  "private": true,
  "bin": {
    "arika": "dist/triggers/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "arika": "node dist/triggers/cli.js",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "commander": "^13.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.3.3",
    "gray-matter": "^4.0.3",
    "node-cron": "^3.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
