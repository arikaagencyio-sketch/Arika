FINOS_DATABASE_URL=postgres://finos:finos@localhost:5432/finos
FINOS_EVENT_STORE=postgres
FINOS_MCP_TRANSPORT=stdio
FINOS_HTTP_HOST=0.0.0.0
FINOS_HTTP_PORT=8787
FINOS_JWT_ISSUER=finos
FINOS_AUDIT_HASH_SECRET=replace-with-rotated-secret
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key

# Zoho Books — real, live org (see GO_LIVE_CHECKLIST.md item 9). Organization ID
# is not secret and is the real one already connected via claude.ai's Zoho Books
# connector. Client ID/secret/refresh token require a one-time Zoho API Console
# "Self Client" OAuth setup (owner action) — see docs/integrations.md.
ZOHO_ORGANIZATION_ID=929138528
ZOHO_CLIENT_ID=replace-with-real-self-client-id
ZOHO_CLIENT_SECRET=replace-with-real-self-client-secret
ZOHO_REFRESH_TOKEN=replace-with-real-refresh-token
# Confirm these match the account's actual sign-in region (accounts.zoho.com
# for the US DC, accounts.zoho.eu for EU, accounts.zoho.in for IN, etc.)
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com/books/v3
