{
  "name": "finos-plugin",
  "version": "0.1.0",
  "description": "Institutional-grade Financial Operating System plugin for 360-degree agency finance operations.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:mcp": "tsx src/api-layer/mcp-server.ts",
    "dev:http": "tsx src/api-layer/http-api.ts",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fastify": "^5.3.3",
    "nats": "^2.29.3",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
